# Copy to .env and adjust. The app runs with the MOCK provider + offline embedder and
# needs none of the keys below; fill them in to enable real reasoning and semantic search.

# --- auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
MIN_PASSWORD_LENGTH=8

# --- storage ---
DATABASE_URL=sqlite:///./lexa.db
# Production example: DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/lexa
VECTOR_STORE_PATH=./data/vectorstore
# Dev convenience: auto-create tables on startup. Set false in production and use Alembic
# (`alembic upgrade head`) to manage the schema.
AUTO_CREATE_TABLES=true

# --- quotas ---
FREE_TIER_QUOTA=5
FREE_TIER_WINDOW_HOURS=24
FREE_TIER_ALLOW_ESCALATION=false

# --- rate limiting ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- CORS (comma-separated in prod) ---
CORS_ORIGINS=*

# --- LLM provider: "mock" (offline) or "live" ---
LLM_PROVIDER=mock
REQUEST_TIMEOUT_SECONDS=60
MAX_PROVIDER_RETRIES=2
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- embeddings: "hashing" (offline), "sentence_transformers", "openai", "google" ---
# Use sentence_transformers (pip install sentence-transformers) in production for real
# semantic retrieval and the cleanest abstention behavior.
EMBEDDINGS_BACKEND=hashing
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
EMBEDDINGS_DIM=256

# --- grounding / abstention thresholds (cosine similarity) ---
GROUNDING_FLOOR=0.12
GROUNDING_STRONG=0.30

# --- email (verification + password reset) ---
APP_BASE_URL=http://localhost:8000
EMAIL_BACKEND=console            # "console" (dev, logs the link) | "smtp"
EMAIL_FROM=no-reply@lexa.legal
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
EMAIL_TOKEN_HOURS=24

# --- live government / public legal sources (fetched at query time) ---
# Turn this on (on a machine with internet) to ground answers in real-time official data.
LIVE_SOURCES_ENABLED=false
# comma list: federal_register (no key), courtlistener (token optional), govinfo (key required)
LIVE_SOURCES=federal_register
LIVE_RESULTS_PER_SOURCE=5
GOVINFO_API_KEY=

# --- ingestion (free public legal source) ---
COURTLISTENER_TOKEN=
